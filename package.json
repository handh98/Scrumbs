{
  "name": "crumbs-app",
  "version": "1.0.8",
  "main": "src/main/main.js",
  "scripts": {
    "start": "chcp 65001 > nul && electron .",
    "rebuild": "electron-rebuild -f -w sqlite3",
    "clean": "rd /s /q node_modules && del package-lock.json",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build": "electron-builder"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/handh98/Scrumbs.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Ứng dụng quản lý tiệm bánh - Ver 1",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "@electron/rebuild": "^4.0.4"
  },
  "dependencies": {
    "electron-log": "^4.4.8",
    "electron-updater": "^6.8.9",
    "sqlite3": "^5.1.7"
  },
  "build": {
    "appId": "com.tiembanh.app",
    "productName": "Scrumbs",
    "publish": [
      {
        "provider": "github",
        "owner": "handh98",
        "repo": "Scrumbs"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "src/renderer/assets/icon.ico"
    },
    "nsis": {
      "installerIcon": "src/renderer/assets/icon.ico",
      "uninstallerIcon": "src/renderer/assets/icon.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Scrumbs"
    }
  }
}
