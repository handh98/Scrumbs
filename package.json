{
  "name": "crumbs-app",
  "version": "1.3.6",
  "main": "src/main/main.js",
  "scripts": {
    "start": "chcp 65001 > nul && electron .",
    "rebuild": "electron-rebuild -f -w sqlite3",
    "clean": "rd /s /q node_modules && del package-lock.json",
    "pack": "electron-builder --dir",
    "dist": "electron-builder -p always",
    "build": "electron-builder -p always",
    "lint": "eslint src --cache --cache-location .eslintcache",
    "lint:fix": "eslint src --fix --cache --cache-location .eslintcache",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/handh98/Scrumbs.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Ứng dụng quản lý tiệm bánh",
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.8.4"
  },
  "dependencies": {
    "@humanfs/node": "^0.16.8",
    "electron-log": "^4.4.8",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "sqlite3": "^5.1.7"
  },
  "lint-staged": {
    "src/**/*.{js,cjs,mjs}": "eslint --fix",
    "**/*.{html,css}": "prettier --write"
  },
  "build": {
    "appId": "com.tiembanh.app",
    "productName": "Scrumbs",
    "publish": [
      {
        "provider": "github",
        "owner": "handh98",
        "repo": "Scrumbs",
        "releaseType": "draft"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "src/renderer/assets/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName}_Setup_${version}.${ext}",
      "installerIcon": "src/renderer/assets/icon.ico",
      "uninstallerIcon": "src/renderer/assets/icon.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Scrumbs"
    }
  }
}
